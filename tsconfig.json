{
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "lib": ["esnext", "dom"],
    "strictNullChecks": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es6",
    "esModuleInterop": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist/js",
    "noEmitOnError": true,
    "typeRoots": [ "node_modules/@types" ],
    "types": ["chrome", "bootstrap", "jest", "react", "react-dom", "node"],
  }
}
